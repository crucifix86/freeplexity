<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF1F1F1F">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:background="#FF141414"
        android:gravity="center_vertical|end"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <ImageView
            android:id="@+id/search_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:padding="6dp"
            android:src="@drawable/ic_search"
            android:background="@drawable/top_bar_icon_bg"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:contentDescription="Search"
            android:nextFocusRight="@+id/settings_button" />

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp">

            <ImageView
                android:id="@+id/settings_button"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/ic_settings"
                android:background="@drawable/top_bar_icon_bg"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:contentDescription="Settings"
                android:nextFocusLeft="@+id/search_button" />

            <TextView
                android:id="@+id/update_badge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:background="@drawable/update_badge_bg"
                android:gravity="center"
                android:text="!"
                android:textColor="#FFFFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>

    <fragment
        android:id="@+id/main_fragment"
        android:name="com.plexclient.ui.main.MainFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
