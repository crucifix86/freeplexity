<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF1F1F1F">

    <!-- Top section: poster + info + actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:paddingBottom="12dp">

        <!-- Poster -->
        <ImageView
            android:id="@+id/detail_poster"
            android:layout_width="120dp"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:background="#FF2A2A2A" />

        <!-- Info + actions -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="20dp">

            <TextView
                android:id="@+id/detail_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFEEEEEE"
                android:textSize="22sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detail_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF999999"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:maxLines="1" />

            <TextView
                android:id="@+id/detail_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF888888"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:maxLines="3"
                android:ellipsize="end" />

            <!-- Action buttons -->
            <LinearLayout
                android:id="@+id/detail_actions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- Content rows below (seasons, episodes, etc.) -->
    <fragment
        android:id="@+id/detail_rows_fragment"
        android:name="com.plexclient.ui.details.DetailRowsFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
